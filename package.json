{
  "name": "dossier",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "db:push": "prisma db push --accept-data-loss",
    "db:seed": "tsx prisma/seed.ts",
    "local": "export DATABASE_URL=\"file:./local.db\" && next dev",
    "local:db:push": "export DATABASE_URL=\"file:./local.db\" && npm run db:push",
    "local:db:seed": "export DATABASE_URL=\"file:./local.db\" && npm run db:seed",
    "pretest": "export DATABASE_URL=\"file:./test.db\" && npm run db:push && npm run db:seed",
    "test": "export DATABASE_URL=\"file:./test.db\" && vitest run",
    "pretest:watch": "export DATABASE_URL=\"file:./test.db\" && npm run db:push && npm run db:seed",
    "test:watch": "export DATABASE_URL=\"file:./test.db\" && vitest"
  },
  "dependencies": {
    "next": "^15.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "@prisma/client": "^6.2.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "prisma": "^6.2.0",
    "tsx": "^4.19.0",
    "dotenv": "^16.4.0",
    "vitest": "^2.1.0",
    "@vitejs/plugin-react": "^4.3.0",
    "jsdom": "^25.0.0",
    "@testing-library/react": "^16.1.0",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/user-event": "^14.5.0"
  }
}
