{
  "name": "dossier",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "db:push": "prisma db push --accept-data-loss",
    "db:seed": "tsx prisma/seed.ts",
    "local": "export DATABASE_URL=\"file:./prisma/local.db\" && next dev",
    "local:db:push": "export DATABASE_URL=\"file:./prisma/local.db\" && npm run db:push",
    "local:db:seed": "export DATABASE_URL=\"file:./prisma/local.db\" && npm run db:seed",
    "pretest": "export DATABASE_URL=\"file:./test.db\" && npm run db:push && npm run db:seed",
    "test": "export DATABASE_URL=\"file:./test.db\" && vitest run",
    "pretest:watch": "export DATABASE_URL=\"file:./test.db\" && npm run db:push && npm run db:seed",
    "test:watch": "export DATABASE_URL=\"file:./test.db\" && vitest",
    "pretest:integration": "export DATABASE_URL=\"file:./integration-test.db\" && npm run db:push",
    "test:integration": "export DATABASE_URL=\"file:./integration-test.db\" && RUN_INTEGRATION_TESTS=1 vitest run --testTimeout=1800000 src/lib/researchEngine.integration.test.ts src/lib/chatEngine.integration.test.ts"
  },
  "dependencies": {
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "dotenv": "^17.4.2",
    "next": "^16.2.10",
    "prisma": "^7.8.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsx": "^4.23.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.0",
    "@types/node": "^26.1.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.3",
    "jsdom": "^29.1.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10"
  }
}
